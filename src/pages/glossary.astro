---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Term {
  term: string;
  description: string;
  example: string;
}

interface Category {
  title: string;
  emoji: string;
  terms: Term[];
}

const categories: Category[] = [
  {
    title: "AI 기초",
    emoji: "🧠",
    terms: [
      { term: "인공지능(AI)", description: "인간의 지능을 모방하는 컴퓨터 시스템", example: "Siri, ChatGPT, Claude" },
      { term: "약한 AI(Narrow AI)", description: "특정 작업 하나에 특화된 AI", example: "체스 AI, 번역기" },
      { term: "일반 AI(AGI)", description: "인간처럼 범용적으로 사고하는 AI", example: "아직 미실현" },
      { term: "알고리즘", description: "문제를 해결하기 위한 단계별 절차", example: "정렬, 검색, 추천 알고리즘" },
      { term: "학습 데이터", description: "AI가 패턴을 배우는 데 사용하는 데이터", example: "고양이 사진 1만 장" },
      { term: "패턴 인식", description: "데이터에서 규칙성을 찾아내는 능력", example: "스팸 메일의 공통 특징 발견" },
      { term: "머신러닝(ML)", description: "데이터에서 패턴을 학습해 예측하는 기술", example: "스팸 분류, 집값 예측" },
      { term: "지도학습", description: "정답 라벨이 있는 데이터로 학습", example: "이메일→스팸/정상" },
      { term: "비지도학습", description: "정답 없이 데이터의 구조를 발견", example: "고객 군집화" },
      { term: "강화학습", description: "보상/패널티로 최적 행동을 학습", example: "AlphaGo, 게임 AI" },
      { term: "과적합(Overfitting)", description: "학습 데이터에만 맞고 새 데이터에 약한 상태", example: "시험 족보만 외운 학생" },
      { term: "데이터셋", description: "학습·평가에 사용하는 데이터 모음", example: "집값 거래 내역 10만 건" },
      { term: "모델", description: "학습된 규칙/패턴의 결과물", example: "집값 예측 모델" },
      { term: "딥러닝", description: "다층 신경망으로 복잡한 패턴을 학습하는 기술", example: "이미지 인식, 번역" },
      { term: "인공 신경망", description: "뇌의 뉴런 구조를 모방한 연산 모델", example: "입력층→은닉층→출력층" },
      { term: "역전파", description: "오차를 뒤에서 앞으로 전파해 가중치를 조정하는 학습법", example: "활쏘기 후 과녁 확인→조준 조정" },
      { term: "CNN", description: "이미지 특징을 단계적으로 추출하는 신경망", example: "얼굴 인식, 의료 영상" },
      { term: "RNN", description: "순서/시간 정보를 기억하며 처리하는 신경망", example: "음성 인식, 주가 예측" },
      { term: "Transformer", description: "문장 전체를 병렬로 이해하는 최신 구조", example: "GPT, Claude, BERT" },
      { term: "GPU", description: "대량 병렬 연산에 특화된 프로세서", example: "NVIDIA A100, H100" },
      { term: "LLM", description: "대규모 텍스트로 학습한 언어 생성 모델", example: "GPT-4, Claude, Gemini" },
      { term: "토큰", description: "LLM이 텍스트를 처리하는 최소 단위", example: "\"안녕하세요\" → 2토큰" },
      { term: "파라미터", description: "모델이 학습한 내부 가중치 수", example: "GPT-3: 1,750억 개" },
      { term: "환각(Hallucination)", description: "사실이 아닌 내용을 자신있게 생성하는 현상", example: "존재하지 않는 논문 인용" },
      { term: "맥락 창(Context Window)", description: "한 번에 처리할 수 있는 토큰 수 제한", example: "128K, 200K, 1M 토큰" },
      { term: "미세조정(Fine-tuning)", description: "사전학습된 모델을 특정 작업에 맞게 추가 학습", example: "의료 상담용 모델" },
      { term: "RLHF", description: "인간 피드백으로 모델 응답 품질을 개선하는 기법", example: "\"이 답변이 더 유용해요\" 선택" },
      { term: "프롬프트", description: "LLM에게 보내는 입력 텍스트(지시·질문)", example: "\"이 코드의 버그를 찾아줘\"" },
    ],
  },
  {
    title: "AI 발전사",
    emoji: "📜",
    terms: [
      { term: "튜링 테스트", description: "기계가 인간과 구분 불가능하면 \"지능적\"이라고 판단하는 기준", example: "챗봇과 대화 시 사람/기계 구분" },
      { term: "AI 겨울", description: "AI 연구에 대한 기대와 투자가 급감한 침체기", example: "1974~1980, 1987~1993" },
      { term: "전문가 시스템", description: "\"만약 ~이면 ~이다\" 규칙을 모아 전문가 지식을 흉내 낸 시스템", example: "의료 진단 규칙 시스템" },
      { term: "퍼셉트론", description: "최초의 학습 가능한 단층 인공 신경망", example: "1958년 로젠블랫 발명" },
      { term: "XOR 문제", description: "단층 퍼셉트론이 풀 수 없는 논리 문제", example: "신경망 연구 침체의 원인" },
      { term: "GAN", description: "생성자와 판별자가 경쟁하며 학습하는 신경망", example: "가짜 얼굴, 이미지 생성" },
      { term: "잔차 연결", description: "층을 건너뛰는 연결로 깊은 신경망 학습을 가능하게 한 기법", example: "ResNet(152층)" },
      { term: "활성화 함수", description: "뉴런의 출력을 결정하는 비선형 함수", example: "ReLU, Sigmoid" },
      { term: "어텐션", description: "입력의 어떤 부분에 집중할지 가중치를 부여하는 메커니즘", example: "주어-동사 연결 파악" },
      { term: "QKV", description: "Query·Key·Value로 단어 간 관련도를 계산하는 구조", example: "도서관 질문→제목 매칭→내용 반환" },
      { term: "인코더", description: "입력을 이해하고 내부 표현으로 변환하는 부분", example: "BERT (텍스트 분류)" },
      { term: "디코더", description: "내부 표현에서 출력을 생성하는 부분", example: "GPT (텍스트 생성)" },
      { term: "스케일링 법칙", description: "모델·데이터·컴퓨팅 증가 시 성능이 예측 가능하게 향상되는 법칙", example: "GPT-3 → GPT-4 도약의 근거" },
      { term: "멀티헤드 어텐션", description: "여러 관점에서 동시에 어텐션을 수행하는 기법", example: "문법·의미·감정 동시 파악" },
      { term: "멀티모달", description: "텍스트·이미지·음성 등 여러 형태의 데이터를 동시에 처리", example: "GPT-4o, Gemini" },
      { term: "오픈소스 모델", description: "가중치가 공개되어 누구나 다운로드·수정 가능한 모델", example: "Llama, Mistral" },
      { term: "에이전트", description: "도구를 사용하고 작업을 자율적으로 수행하는 AI", example: "Claude Code, Devin" },
      { term: "증류(Distillation)", description: "대형 모델의 지식을 소형 모델로 압축하는 기법", example: "GPT-4 → GPT-4o mini" },
      { term: "API", description: "프로그램에서 AI 모델을 호출하는 인터페이스", example: "OpenAI API, Anthropic API" },
    ],
  },
  {
    title: "엔지니어링 기법",
    emoji: "⚙️",
    terms: [
      { term: "프롬프트 엔지니어링", description: "AI에게 효과적인 입력을 설계하는 기술", example: "역할+맥락+지시+형식+제약" },
      { term: "페르소나", description: "AI에게 부여하는 전문가 역할", example: "\"당신은 시니어 개발자입니다\"" },
      { term: "Few-shot", description: "예시를 함께 제공해 출력 패턴을 유도하는 기법", example: "2~3개 입출력 예시 제공" },
      { term: "Chain of Thought", description: "단계적 사고를 유도해 추론 정확도를 높이는 기법", example: "\"단계별로 풀어주세요\"" },
      { term: "네거티브 프롬프팅", description: "하지 말아야 할 것을 명시하는 기법", example: "\"전문 용어를 사용하지 마세요\"" },
      { term: "시스템 프롬프트", description: "AI의 행동 규칙을 정의하는 초기 설정", example: "역할, 톤, 형식 규칙 지정" },
      { term: "컨텍스트 엔지니어링", description: "AI에게 전달하는 맥락을 체계적으로 설계하는 기술", example: "CLAUDE.md + 참조 자료 + 대화 기록" },
      { term: "컨텍스트", description: "AI에게 전달하는 배경 정보·참조 자료의 총체", example: "시스템 프롬프트, 코드, 문서" },
      { term: "RAG", description: "질문에 관련된 문서를 검색해 컨텍스트에 추가하는 기법", example: "사내 위키 자동 검색" },
      { term: "CLAUDE.md", description: "Claude Code에서 프로젝트 규칙을 지속 전달하는 파일", example: "코딩 컨벤션, 아키텍처 규칙" },
      { term: "청크 분할", description: "긴 문서를 의미 단위로 나눠 필요한 부분만 제공", example: "10만 줄 코드 → 관련 파일 3개" },
      { term: "도구 사용(Tool Use)", description: "AI가 외부 기능(파일, API 등)을 호출하는 능력", example: "파일 읽기, 셸 명령 실행" },
      { term: "오케스트레이터", description: "서브에이전트에게 작업을 위임하는 메인 에이전트", example: "코드·테스트·리뷰 에이전트 관리" },
      { term: "OTA 루프", description: "관찰(Observe)-사고(Think)-행동(Act) 반복 구조", example: "에러 확인 → 분석 → 수정" },
      { term: "샌드박스", description: "에이전트의 실행 환경을 격리하는 보안 장치", example: "Docker 컨테이너, 가상 환경" },
      { term: "하네스", description: "에이전트의 행동을 통제·관리하는 프레임워크", example: "권한·승인·모니터링 시스템" },
      { term: "가드레일", description: "에이전트 출력을 검증·필터링하는 안전 레이어", example: "위험 명령 차단, 코드 검증" },
      { term: "승인 게이트", description: "위험도에 따라 자동/수동 승인을 분기하는 장치", example: "파일 삭제 시 사람 승인 필요" },
      { term: "에스컬레이션", description: "에이전트가 판단 어려운 상황을 상위로 넘기는 것", example: "\"테스트 없이 진행할까요?\"" },
      { term: "체크포인트", description: "작업 전 상태를 저장해 실패 시 복원하는 기법", example: "git stash, 스냅샷" },
    ],
  },
  {
    title: "Claude Code 도구",
    emoji: "🔧",
    terms: [
      { term: "Claude Code", description: "Anthropic의 공식 터미널 기반 AI 코딩 도구", example: "claude 명령으로 실행" },
      { term: "에이전틱 코딩", description: "AI가 코드를 직접 읽고·수정·실행하는 방식", example: "파일 편집 + 셸 명령 + 테스트" },
      { term: "승인 프롬프트", description: "위험한 작업 전 사용자에게 확인을 요청하는 안전장치", example: "파일 수정·셸 명령 실행 전 확인" },
      { term: "멀티파일 작업", description: "여러 파일을 동시에 읽고 수정하는 능력", example: "30개 파일 TypeScript 변환" },
      { term: "스킬", description: "슬래시 명령으로 실행하는 체계적 작업 절차", example: "/ship, /review, /qa" },
      { term: "Hook", description: "특정 이벤트 발생 시 자동 실행되는 스크립트", example: "커밋 전 린트, 수정 후 포매팅" },
      { term: "슬래시 명령", description: "/로 시작하는 스킬 실행 명령", example: "/investigate" },
      { term: "플러그인", description: "Claude Code의 핵심 동작을 변경·확장하는 시스템", example: "커스텀 도구, 외부 연동" },
      { term: "트리거", description: "스킬이 활성화되는 조건", example: "\"테스트를 실행해 줘\" 요청 시" },
      { term: "메인 에이전트", description: "사용자와 대화하며 전체 작업을 관리하는 에이전트", example: "Claude Code 본체" },
      { term: "서브에이전트", description: "메인이 생성한 독립 작업 단위", example: "파일 분석, 코드 검색 담당" },
      { term: "위임(Delegation)", description: "메인이 서브에이전트에게 작업을 넘기는 것", example: "보안 점검 3개 영역 병렬 위임" },
      { term: "병렬 실행", description: "여러 서브에이전트가 동시에 작업하는 것", example: "3개 파일 동시 리뷰" },
      { term: "컨텍스트 분리", description: "서브에이전트가 별도 대화 공간에서 작업하는 것", example: "메인 컨텍스트 낭비 방지" },
      { term: "MCP", description: "AI를 외부 시스템에 연결하는 표준 프로토콜", example: "AI 세계의 USB" },
      { term: "MCP 서버", description: "데이터·도구를 AI에 제공하는 서비스", example: "GitHub, PostgreSQL 서버" },
      { term: "MCP 호스트", description: "AI 모델이 실행되는 환경", example: "Claude Code, Claude Desktop" },
      { term: "리소스", description: "MCP를 통해 AI가 읽을 수 있는 데이터", example: "github://repos/.../issues" },
    ],
  },
];

const totalTerms = categories.reduce((sum, cat) => sum + cat.terms.length, 0);
---

<BaseLayout title="용어사전" description="AI Guide에서 다루는 주요 용어를 카테고리별로 정리합니다">
  <div class="mx-auto max-w-content px-6 py-12">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">📖 용어사전</h1>
    <p class="mb-4 text-text-secondary">
      AI Guide 전체에서 다루는 주요 용어 {totalTerms}개를 카테고리별로 정리했습니다.
    </p>

    <!-- 카테고리 빠른 이동 -->
    <div class="mb-8 flex flex-wrap gap-2">
      {categories.map((cat) => (
        <a
          href={`#${cat.title}`}
          class="rounded-lg bg-bg-secondary px-3 py-1.5 text-sm text-text-secondary no-underline transition-colors hover:bg-accent/10 hover:text-accent"
        >
          {cat.emoji} {cat.title} ({cat.terms.length})
        </a>
      ))}
    </div>

    <!-- 카테고리별 용어 테이블 -->
    {categories.map((cat) => (
      <section id={cat.title} class="mb-10">
        <h2 class="mb-4 text-xl font-bold">
          {cat.emoji} {cat.title}
        </h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse overflow-hidden rounded-lg border border-border-secondary">
            <thead class="bg-bg-secondary">
              <tr>
                <th class="border-b border-border-primary px-4 py-3 text-left text-sm font-semibold">용어</th>
                <th class="border-b border-border-primary px-4 py-3 text-left text-sm font-semibold">설명</th>
                <th class="border-b border-border-primary px-4 py-3 text-left text-sm font-semibold">예시</th>
              </tr>
            </thead>
            <tbody>
              {cat.terms.map((t) => (
                <tr class="transition-colors hover:bg-bg-secondary">
                  <td class="border-b border-border-secondary px-4 py-2.5 text-sm font-medium text-text-primary whitespace-nowrap">{t.term}</td>
                  <td class="border-b border-border-secondary px-4 py-2.5 text-sm text-text-secondary">{t.description}</td>
                  <td class="border-b border-border-secondary px-4 py-2.5 text-sm text-text-tertiary">{t.example}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
