---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("ai-history", ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => a.data.order - b.data.order);

const levelColors: Record<string, string> = {
  입문: "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200",
  초급: "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200",
  중급: "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200",
  고급: "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200",
};
---

<BaseLayout title="AI 발전사" description="인공지능의 역사와 발전 과정을 살펴봅니다">
  <div class="mx-auto max-w-content px-6 py-12">
    <h1 class="mb-2 text-3xl font-bold tracking-tight">📜 AI 발전사</h1>
    <p class="mb-8 text-text-secondary">
      인공지능의 역사와 발전 과정을 살펴봅니다.
    </p>

    {posts.length > 0 ? (
      <ul class="space-y-4">
        {posts.map((post) => (
          <li>
            <a
              href={`/ai-guide/ai-history/${post.slug}`}
              class="block rounded-lg border border-border-primary bg-bg-secondary p-5 transition-colors hover:border-accent"
            >
              <div class="mb-2 flex items-center gap-2">
                <h2 class="text-lg font-semibold">{post.data.title}</h2>
                <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${levelColors[post.data.level]}`}>
                  {post.data.level}
                </span>
              </div>
              <p class="text-sm text-text-secondary">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="rounded-lg border border-border-primary bg-bg-secondary p-8 text-center">
        <p class="text-text-secondary">아직 콘텐츠가 준비 중이에요 ✏️</p>
      </div>
    )}
  </div>
</BaseLayout>
