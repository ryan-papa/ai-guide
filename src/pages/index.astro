---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="홈">
  <div class="flex min-h-[calc(100vh-4rem)] items-center justify-center px-6">
    <div class="max-w-content text-center">
      <h1 class="mb-4 text-4xl font-bold tracking-tight">
        AI Guide
      </h1>
      <p class="mb-8 text-lg text-text-secondary">
        AI 기술을 쉽고 깊이 있게 이해하기 위한 가이드
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/ai-guide/ai-basics/what-is-ai/" class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary no-underline transition-colors hover:bg-accent/10 hover:text-accent">
          🧠 AI 기초
        </a>
        <a href="/ai-guide/ai-history/ai-timeline/" class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary no-underline transition-colors hover:bg-accent/10 hover:text-accent">
          📜 AI 발전사
        </a>
        <a href="/ai-guide/engineering/prompt-engineering/" class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary no-underline transition-colors hover:bg-accent/10 hover:text-accent">
          ⚙️ 엔지니어링
        </a>
        <a href="/ai-guide/claude-code/what-is-claude-code/" class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary no-underline transition-colors hover:bg-accent/10 hover:text-accent">
          🔧 Claude Code
        </a>
        <a href="/ai-guide/glossary/" class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary no-underline transition-colors hover:bg-accent/10 hover:text-accent">
          📖 용어사전
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
