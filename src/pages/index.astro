---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="홈">
  <main class="flex min-h-screen items-center justify-center px-6">
    <div class="max-w-content text-center">
      <h1 class="mb-4 text-4xl font-bold tracking-tight">
        AI Guide
      </h1>
      <p class="mb-8 text-lg text-text-secondary">
        AI 기술을 쉽고 깊이 있게 이해하기 위한 가이드
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <span class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary">
          AI 기초
        </span>
        <span class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary">
          AI 발전사
        </span>
        <span class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary">
          엔지니어링
        </span>
        <span class="rounded-lg bg-bg-secondary px-4 py-2 text-sm text-text-secondary">
          Claude Code
        </span>
      </div>
    </div>
  </main>
</BaseLayout>
