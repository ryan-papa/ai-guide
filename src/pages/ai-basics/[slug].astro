---
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allPosts = await getCollection("ai-basics", ({ data }) => !data.draft);
  const sorted = allPosts.sort((a, b) => a.data.order - b.data.order);

  return sorted.map((post, idx) => ({
    params: { slug: post.slug },
    props: {
      post,
      prevPost: sorted[idx - 1] ?? null,
      nextPost: sorted[idx + 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await post.render();

const basePath = "/ai-guide/ai-basics";
---

<ArticleLayout
  title={post.data.title}
  description={post.data.description}
  category="AI 기초"
  difficulty={post.data.level}
>
  <Content />

  <!-- 이전/다음 글 네비게이션 -->
  <nav class="mt-12 border-t border-border-secondary pt-8">
    <div class="flex items-stretch justify-between gap-4">
      {prevPost ? (
        <a
          href={`${basePath}/${prevPost.slug}`}
          class="group flex flex-1 flex-col rounded-lg border border-border-primary p-4 transition-colors hover:border-accent"
        >
          <span class="text-xs text-text-secondary">이전 글</span>
          <span class="mt-1 font-medium group-hover:text-accent">
            {prevPost.data.title}
          </span>
        </a>
      ) : (
        <div class="flex-1" />
      )}

      {nextPost ? (
        <a
          href={`${basePath}/${nextPost.slug}`}
          class="group flex flex-1 flex-col items-end rounded-lg border border-border-primary p-4 text-right transition-colors hover:border-accent"
        >
          <span class="text-xs text-text-secondary">다음 글</span>
          <span class="mt-1 font-medium group-hover:text-accent">
            {nextPost.data.title}
          </span>
        </a>
      ) : (
        <div class="flex-1" />
      )}
    </div>
  </nav>
</ArticleLayout>
