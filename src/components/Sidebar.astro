---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

interface NavItem {
  label: string;
  href: string;
}

interface NavCategory {
  title: string;
  emoji: string;
  items: NavItem[];
}

const navigation: NavCategory[] = [
  {
    title: "AI 기초",
    emoji: "🧠",
    items: [
      { label: "AI란 무엇인가요?", href: `${base}ai-basics/what-is-ai/` },
      { label: "머신러닝 이해하기", href: `${base}ai-basics/machine-learning/` },
      { label: "딥러닝 배우기", href: `${base}ai-basics/deep-learning/` },
      { label: "LLM이란?", href: `${base}ai-basics/llm/` },
    ],
  },
  {
    title: "AI 발전사",
    emoji: "📜",
    items: [
      { label: "AI 타임라인", href: `${base}ai-history/ai-timeline/` },
      { label: "신경망 혁명", href: `${base}ai-history/neural-network-revolution/` },
      { label: "트랜스포머의 등장", href: `${base}ai-history/transformer-era/` },
      { label: "현대 AI 모델 비교", href: `${base}ai-history/modern-ai-models/` },
    ],
  },
  {
    title: "엔지니어링 기법",
    emoji: "⚙️",
    items: [
      { label: "프롬프트 엔지니어링", href: `${base}engineering/prompt-engineering/` },
      { label: "컨텍스트 엔지니어링", href: `${base}engineering/context-engineering/` },
      { label: "에이전틱 엔지니어링", href: `${base}engineering/agentic-engineering/` },
      { label: "하네스 엔지니어링", href: `${base}engineering/harness-engineering/` },
    ],
  },
  {
    title: "Claude Code 도구",
    emoji: "🔧",
    items: [
      { label: "Claude Code란?", href: `${base}claude-code/what-is-claude-code/` },
      { label: "스킬과 플러그인", href: `${base}claude-code/skills-and-plugins/` },
      { label: "에이전트와 서브에이전트", href: `${base}claude-code/agents-and-subagents/` },
      { label: "MCP와 커넥터", href: `${base}claude-code/mcp-and-connectors/` },
    ],
  },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href.replace(/\/$/, "");
}
---

<aside
  class="fixed left-0 top-16 hidden h-[calc(100vh-4rem)] w-64 overflow-y-auto border-r border-border-secondary bg-bg-primary pb-8 pt-6 lg:block"
>
  <nav class="px-4">
    {
      navigation.map((category) => (
        <div class="mb-6">
          <h3 class="mb-2 px-3 text-xs font-semibold uppercase tracking-wider text-text-tertiary">
            <span class="mr-1.5">{category.emoji}</span>
            {category.title}
          </h3>
          <ul class="space-y-0.5">
            {category.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "block rounded-lg px-3 py-2 text-sm no-underline transition-colors",
                    isActive(item.href)
                      ? "bg-accent/10 font-medium text-accent"
                      : "text-text-secondary hover:bg-bg-secondary hover:text-text-primary",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>
